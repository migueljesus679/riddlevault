# === Gandalf - Configuracao ===

# MongoDB
MONGO_URI=mongodb://mongo:27017/gandalf
MONGO_INITDB_DATABASE=gandalf

# Node API
NODE_PORT=3001
NODE_ENV=development

# Python API
PYTHON_PORT=8000
PYTHON_API_URL=http://api-python:8000

# Seguranca (gerar com: node scripts/generate-keys.ts)
ENCRYPTION_KEY=change-me-generate-with-script
JWT_SECRET=change-me-generate-with-script

# OpenAI
OPENAI_API_KEY=your-openai-key-here

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key-here

# Google OAuth2 (Gmail + Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/integrations/google/callback

# Microsoft OAuth2 (Outlook + OneDrive)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3001/integrations/microsoft/callback

# Dropbox OAuth2
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:3001/integrations/dropbox/callback
